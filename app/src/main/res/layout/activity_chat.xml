<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    tools:context=".ChatActivity">

    <!-- ── Chat Header ── -->
    <LinearLayout
        android:id="@+id/chatHeader"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:background="@color/bg_card"
        android:elevation="2dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Back button -->
        <LinearLayout
            android:id="@+id/chatBtnBack"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:gravity="center"
            android:background="@drawable/bg_detail_header_btn"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="10dp">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_chevron_right"
                android:rotation="180"
                app:tint="@color/unipazar_orange"/>
        </LinearLayout>

        <!-- Other user avatar -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="42dp"
            android:layout_height="42dp"
            app:cardCornerRadius="21dp"
            app:cardElevation="0dp"
            android:layout_marginEnd="10dp">
            <ImageView
                android:id="@+id/ivChatAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/sym_def_app_icon"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- Name and product -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvChatOtherName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="Emir Yılmaz"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>

            <TextView
                android:id="@+id/tvChatAdTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="Calculus Kitabı"
                android:textSize="12sp"
                android:textColor="@color/text_hint"
                android:singleLine="true"/>
        </LinearLayout>

        <!-- Ad thumbnail -->
        <androidx.cardview.widget.CardView
            android:layout_width="42dp"
            android:layout_height="42dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp">
            <ImageView
                android:id="@+id/ivChatAdThumb"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@color/bg_input"/>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- ── Message Input Bar (Bottom) ── -->
    <LinearLayout
        android:id="@+id/chatInputBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/bg_card"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_input_field"
            android:paddingHorizontal="14dp"
            android:layout_marginEnd="10dp">

            <ImageView
                android:id="@+id/btnAttachImage"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_camera_plus"
                android:layout_marginEnd="8dp"
                app:tint="@color/text_secondary"
                android:clickable="true"
                android:focusable="true"/>

            <EditText
                android:id="@+id/etChatInput"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:hint="Mesaj yaz..."
                android:textColorHint="@color/text_hint"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:singleLine="false"
                android:maxLines="3"
                android:imeOptions="actionSend"
                android:inputType="textMultiLine"/>
        </LinearLayout>

        <!-- Send button -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btnSendMessage"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/unipazar_orange"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_chevron_right"
                android:layout_gravity="center"
                android:scaleType="fitCenter"/>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- ── Message List ── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/chatHeader"
        app:layout_constraintBottom_toTopOf="@id/chatInputBar"/>

</androidx.constraintlayout.widget.ConstraintLayout>
