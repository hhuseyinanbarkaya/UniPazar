<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    tools:context=".MessagesActivity">

    <!-- ── Header ── -->
    <LinearLayout
        android:id="@+id/msgHeader"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@color/bg_card"
        android:elevation="1dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_grad_cap"
            android:scaleType="fitCenter"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Mesajlarım"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/unipazar_orange"
            android:layout_marginStart="8dp"/>

        <ImageView
            android:id="@+id/btnMsgNotif"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_bell"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/text_dark_gray"/>
    </LinearLayout>

    <!-- ── Bottom Nav ── -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/msgBottomNav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/bg_card"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:id="@+id/tabMsgHome"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@drawable/ic_home" app:tint="@color/text_secondary"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Ana Sayfa" android:textSize="10sp" android:textColor="@color/text_secondary" android:layout_marginTop="2dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tabMsgSearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@drawable/ic_search" app:tint="@color/text_secondary"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Arama" android:textSize="10sp" android:textColor="@color/text_secondary" android:layout_marginTop="2dp"/>
            </LinearLayout>

            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.2"/>

            <LinearLayout
                android:id="@+id/tabMsgMessages"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@drawable/ic_chat" app:tint="@color/unipazar_orange"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Mesajlar" android:textSize="10sp" android:textColor="@color/unipazar_orange" android:layout_marginTop="2dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tabMsgProfile"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@drawable/ic_profile" app:tint="@color/text_secondary"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Profil" android:textSize="10sp" android:textColor="@color/text_secondary" android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ── FAB center ── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardMsgFab"
        android:layout_width="54dp"
        android:layout_height="54dp"
        app:cardCornerRadius="27dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="@color/unipazar_orange"
        app:layout_constraintTop_toTopOf="@id/msgBottomNav"
        app:layout_constraintBottom_toTopOf="@id/msgBottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_plus"
            android:layout_gravity="center"
            android:scaleType="fitCenter"/>
    </androidx.cardview.widget.CardView>

    <!-- ── Content ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/msgHeader"
        app:layout_constraintBottom_toTopOf="@id/msgBottomNav">

        <!-- Search bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_input_field"
            android:paddingHorizontal="14dp"
            android:layout_margin="16dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_search"
                app:tint="@color/text_hint"
                android:layout_marginEnd="8dp"/>

            <EditText
                android:id="@+id/etMsgSearch"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:hint="Mesajlarda veya kişilerde ara..."
                android:textColorHint="@color/text_hint"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:singleLine="true"
                android:imeOptions="actionSearch"/>
        </LinearLayout>

        <!-- Filter tabs -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/tabFilterAll"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="Hepsi"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/bg_card"
                android:background="@drawable/bg_tab_active"
                android:paddingHorizontal="18dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/tabFilterUnread"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="Okunmamış"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:background="@drawable/bg_input_field"
                android:paddingHorizontal="18dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/tabFilterBought"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="Satın Alınanlar"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:background="@drawable/bg_input_field"
                android:paddingHorizontal="18dp"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Conversations list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvConversations"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"/>

        <!-- Empty state -->
        <LinearLayout
            android:id="@+id/llEmptyState"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">
            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_chat"
                app:tint="@color/divider_color"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Henüz mesajınız yok"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_hint"
                android:layout_marginTop="12dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="İlan detayından satıcıya mesaj gönderin"
                android:textSize="13sp"
                android:textColor="#D1D5DB"
                android:layout_marginTop="6dp"
                android:gravity="center"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
