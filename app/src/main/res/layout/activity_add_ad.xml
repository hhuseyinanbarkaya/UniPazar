<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    tools:context=".AddAdActivity">

    <!-- ── Pinned Header ── -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/llHeader"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/bg_card"
        android:elevation="1dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginStart="16dp"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_grad_cap"
                android:scaleType="fitCenter"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="İlan Ver"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/unipazar_orange"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/ivNotificationsBell"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_bell"
            android:padding="10dp"
            android:scaleType="fitCenter"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="12dp"
            app:tint="@color/text_secondary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ── Bottom Navigation Bar ── -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cardBottomNavAdd"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/bg_card"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Home Tab -->
            <LinearLayout
                android:id="@+id/tabAddHome"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_home"
                    app:tint="@color/text_secondary"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ana Sayfa"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Search Tab -->
            <LinearLayout
                android:id="@+id/tabAddSearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_search"
                    app:tint="@color/text_secondary"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Arama"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Post Placeholder -->
            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.2"/>

            <!-- Messages Tab -->
            <LinearLayout
                android:id="@+id/tabAddMessages"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_chat"
                    app:tint="@color/text_secondary"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mesajlar"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Profile Tab -->
            <LinearLayout
                android:id="@+id/tabAddProfile"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_profile"
                    app:tint="@color/text_secondary"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Profil"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ── Overlapping Post Button ── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardFabAddPage"
        android:layout_width="54dp"
        android:layout_height="54dp"
        app:cardCornerRadius="27dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="@color/unipazar_orange"
        app:layout_constraintTop_toTopOf="@id/cardBottomNavAdd"
        app:layout_constraintBottom_toTopOf="@id/cardBottomNavAdd"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_plus"
            android:layout_gravity="center"
            android:scaleType="fitCenter"/>
    </androidx.cardview.widget.CardView>

    <!-- ── Scrollable Content ── -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollAddContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/llHeader"
        app:layout_constraintBottom_toTopOf="@id/cardBottomNavAdd">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── Satıyorum / Arıyorum Toggle ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="52dp"
                app:cardCornerRadius="50dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/bg_input"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:padding="4dp"
                    android:gravity="center_vertical">

                    <!-- Satıyorum tab -->
                    <LinearLayout
                        android:id="@+id/tabSatiyorum"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="@drawable/bg_tab_active"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:id="@+id/ivTabSatiyorumIcon"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_tag"
                            android:layout_marginEnd="6dp"
                            app:tint="@color/bg_card"/>
                        <TextView
                            android:id="@+id/tvTabSatiyorum"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Satıyorum"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/bg_card"/>
                    </LinearLayout>

                    <!-- Arıyorum tab -->
                    <LinearLayout
                        android:id="@+id/tabAriyorum"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="@drawable/bg_tab_inactive"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:id="@+id/ivTabAriyorumIcon"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_wanted"
                            android:layout_marginEnd="6dp"
                            app:tint="@color/text_secondary"/>
                        <TextView
                            android:id="@+id/tvTabAriyorum"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Arıyorum"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_secondary"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Photo Upload Row ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <!-- Upload button -->
                <LinearLayout
                    android:id="@+id/btnSelectImages"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_dashed_upload"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="12dp">
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_camera_plus"
                        app:tint="@color/unipazar_orange"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fotoğraf Ekle"
                        android:textSize="11sp"
                        android:textColor="@color/unipazar_orange"
                        android:layout_marginTop="6dp"
                        android:gravity="center"/>
                </LinearLayout>

                <!-- Selected images horizontal list -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvSelectedImages"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/item_selected_image"/>
            </LinearLayout>

            <!-- ── İlan Başlığı ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="İlan Başlığı"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark_gray"
                android:layout_marginBottom="6dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_input_field"
                android:paddingHorizontal="14dp"
                android:layout_marginBottom="16dp">
                <EditText
                    android:id="@+id/etTitle"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:hint="Örn: Orijinal Kalkülüs Kitabı - Az Kullanılmış"
                    android:textColorHint="@color/text_hint"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:inputType="text"
                    android:singleLine="true"/>
            </LinearLayout>

            <!-- ── Kategori ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kategori"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark_gray"
                android:layout_marginBottom="6dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_input_field"
                android:paddingHorizontal="14dp"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:id="@+id/tvCategorySelected"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Seçiniz"
                    android:textColor="@color/text_hint"
                    android:textSize="14sp"/>
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right"
                    android:rotation="90"
                    app:tint="@color/text_hint"/>
            </LinearLayout>

            <!-- Hidden spinner for category logic -->
            <Spinner
                android:id="@+id/spinnerCategory"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:visibility="gone"/>

            <!-- ── Fiyat (TL) ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fiyat (TL)"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark_gray"
                android:layout_marginBottom="6dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_input_field"
                android:paddingHorizontal="14dp"
                android:layout_marginBottom="16dp">
                <EditText
                    android:id="@+id/etPrice"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="500"
                    android:textColorHint="@color/text_hint"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:inputType="numberDecimal"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₺"
                    android:textSize="18sp"
                    android:textColor="@color/unipazar_orange"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- ── Üniversite ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Üniversite"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark_gray"
                android:layout_marginBottom="6dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_input_field"
                android:paddingHorizontal="14dp"
                android:layout_marginBottom="16dp">
                <EditText
                    android:id="@+id/etUniversity"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="Üniversiteniz"
                    android:textColorHint="@color/text_hint"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:inputType="text"
                    android:singleLine="true"/>
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_grad_cap"
                    app:tint="@color/text_hint"/>
            </LinearLayout>

            <!-- ── Kampüs ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kampüs"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark_gray"
                android:layout_marginBottom="6dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_input_field"
                android:paddingHorizontal="14dp"
                android:layout_marginBottom="16dp">
                <EditText
                    android:id="@+id/etCampus"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="Kampüs adı"
                    android:textColorHint="@color/text_hint"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:inputType="text"
                    android:singleLine="true"/>
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_compass"
                    app:tint="@color/text_hint"/>
            </LinearLayout>

            <!-- ── Açıklama ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Açıklama"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark_gray"
                android:layout_marginBottom="6dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:orientation="horizontal"
                android:gravity="top"
                android:background="@drawable/bg_input_field"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp"
                android:layout_marginBottom="16dp">
                <EditText
                    android:id="@+id/etDescription"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:hint="Ürün hakkında detaylar..."
                    android:textColorHint="@color/text_hint"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:gravity="top"
                    android:inputType="textMultiLine"/>
            </LinearLayout>

            <!-- ── İletişim ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="İletişim Bilgisi"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark_gray"
                android:layout_marginBottom="6dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_input_field"
                android:paddingHorizontal="14dp"
                android:layout_marginBottom="24dp">
                <EditText
                    android:id="@+id/etContactInfo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:hint="Tel veya Instagram"
                    android:textColorHint="@color/text_hint"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:inputType="text"
                    android:singleLine="true"/>
            </LinearLayout>

            <!-- ── Submit Button ── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmit"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="İlanı Yayınla →"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/bg_card"
                app:backgroundTint="@color/unipazar_orange"
                app:cornerRadius="16dp"
                android:layout_marginBottom="16dp"/>

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminateTint="@color/unipazar_orange"
                android:visibility="gone"
                android:layout_marginBottom="16dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
