<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="16dp"
    android:background="@color/bg_card"
    android:clickable="true"
    android:focusable="true">

    <!-- Avatar with online dot -->
    <FrameLayout
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginEnd="14dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="56dp"
            android:layout_height="56dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">
            <ImageView
                android:id="@+id/ivConvAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/sym_def_app_icon"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- Online dot -->
        <View
            android:id="@+id/viewOnlineDot"
            android:layout_width="13dp"
            android:layout_height="13dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="1dp"
            android:background="@drawable/dot_online"
            android:visibility="gone"/>
    </FrameLayout>

    <!-- Main content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Name + time row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvConvName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                tools:text="Emir Yılmaz"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:singleLine="true"/>

            <TextView
                android:id="@+id/tvConvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="12:45"
                android:textSize="12sp"
                android:textColor="@color/text_hint"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Last message + unread badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="3dp">

            <TextView
                android:id="@+id/tvConvLastMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                tools:text="Fiyatta son bir şe..."
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:singleLine="true"
                android:ellipsize="end"/>

            <!-- Unread badge -->
            <TextView
                android:id="@+id/tvConvUnreadBadge"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:gravity="center"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/bg_card"
                android:background="@drawable/badge_bg"
                android:backgroundTint="@color/unipazar_orange"
                tools:text="1"
                android:layout_marginStart="6dp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Ad name row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@android:drawable/ic_menu_agenda"
                app:tint="@color/text_hint"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/tvConvAdTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="Calculus 101 Kitabı"
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                android:singleLine="true"
                android:ellipsize="end"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Ad thumbnail -->
    <androidx.cardview.widget.CardView
        android:layout_width="50dp"
        android:layout_height="50dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="0dp"
        android:layout_marginStart="12dp">
        <ImageView
            android:id="@+id/ivConvAdThumbnail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="@color/bg_input"/>
    </androidx.cardview.widget.CardView>

</LinearLayout>
