<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/bg_card_top_rounded">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Filtrele ve Sırala"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp" />

    <!-- Sort By -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sıralama Ölçütü"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/text_dark_gray"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/rgSortOptions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="20dp">

        <RadioButton
            android:id="@+id/rbSortNewest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="En Yeni İlanlar (Varsayılan)"
            android:textColor="@color/text_primary"
            android:checked="true" />

        <RadioButton
            android:id="@+id/rbSortLowestPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="En Düşük Fiyat"
            android:textColor="@color/text_primary" />

        <RadioButton
            android:id="@+id/rbSortHighestPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="En Yüksek Fiyat"
            android:textColor="@color/text_primary" />
    </RadioGroup>

    <!-- Ad Type -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="İlan Tipi"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/text_dark_gray"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/rgAdTypeOptions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">

        <RadioButton
            android:id="@+id/rbAdTypeAll"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tümü"
            android:textColor="@color/text_primary"
            android:checked="true" />

        <RadioButton
            android:id="@+id/rbAdTypeSelling"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Satıyorum"
            android:textColor="@color/text_primary" />

        <RadioButton
            android:id="@+id/rbAdTypeBuying"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Arıyorum"
            android:textColor="@color/text_primary" />
    </RadioGroup>

    <!-- Price Range -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Fiyat Aralığı (TL)"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/text_dark_gray"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <EditText
            android:id="@+id/etMinPrice"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_input_field"
            android:hint="Min"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:inputType="numberDecimal"
            android:paddingHorizontal="16dp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="-"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:textSize="18sp"
            android:layout_marginEnd="8dp" />

        <EditText
            android:id="@+id/etMaxPrice"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_input_field"
            android:hint="Max"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:inputType="numberDecimal"
            android:paddingHorizontal="16dp" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnApplyFilter"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Filtreyi Uygula"
        android:textColor="@color/white"
        app:backgroundTint="@color/unipazar_orange"
        app:cornerRadius="26dp"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/btnClearFilter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Filtreleri Temizle"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:padding="12dp"
        android:layout_marginTop="8dp"
        android:clickable="true"
        android:focusable="true" />
</LinearLayout>
