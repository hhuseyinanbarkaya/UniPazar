<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="10dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="6dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="?attr/colorSurface">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="12dp">

        <LinearLayout
            android:id="@+id/llSellerHeaderShimmer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="8dp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toTopOf="parent">

            <View
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/shimmer_shape" />

            <View
                android:layout_width="120dp"
                android:layout_height="16dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/shimmer_shape"/>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <View
                android:layout_width="60dp"
                android:layout_height="14dp"
                android:background="@drawable/shimmer_shape"/>
        </LinearLayout>

        <View
            android:id="@+id/ivAdImageShimmer"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_marginStart="16dp"
            android:background="@drawable/shimmer_shape"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/llSellerHeaderShimmer" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            app:layout_constraintStart_toEndOf="@id/ivAdImageShimmer"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/llSellerHeaderShimmer"
            app:layout_constraintBottom_toBottomOf="@id/ivAdImageShimmer">

            <View
                android:layout_width="match_parent"
                android:layout_height="20dp"
                android:background="@drawable/shimmer_shape"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/shimmer_shape"/>
            
            <View
                android:layout_width="80dp"
                android:layout_height="14dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/shimmer_shape"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <View
                android:layout_width="80dp"
                android:layout_height="24dp"
                android:background="@drawable/shimmer_shape"/>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
